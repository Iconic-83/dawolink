{
  "version": 2,
  "builds": [
    {
      "src": "api/index.ts",
      "use": "@vercel/node",
      "config": {
        "bundle": true,
        "maxLambdaSize": "50mb",
        "includeFiles": [
          "node_modules/.prisma/**",
          "node_modules/@prisma/client/schema.prisma"
        ]
      }
    }
  ],
  "routes": [
    { "src": "/(.*)", "dest": "/api/index" }
  ]
}
