{
  "version": 2,
  "builds": [
    {
      "src": "api/[...slug].ts",
      "use": "@vercel/node",
      "config": {
        "bundle": true,
        "maxLambdaSize": "50mb",
        "includeFiles": [
          "packages/**",
          "apps/api/src/**",
          "node_modules/.prisma/**",
          "node_modules/@prisma/client/schema.prisma"
        ]
      }
    }
  ]
}
