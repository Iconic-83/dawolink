# ─── Database ───────────────────────────────────────────────────────────────
# Railway auto-injects DATABASE_URL when you add a PostgreSQL plugin
DATABASE_URL="postgresql://postgres:password@localhost:5432/dawolink"

# ─── Redis ──────────────────────────────────────────────────────────────────
# Railway auto-injects REDIS_URL when you add a Redis plugin
REDIS_URL="redis://localhost:6379"

# ─── Auth ───────────────────────────────────────────────────────────────────
# Generate a strong secret: openssl rand -hex 64
JWT_SECRET="change-this-to-a-long-random-secret-in-production"
JWT_EXPIRES_IN="7d"

# ─── API ────────────────────────────────────────────────────────────────────
PORT=4000
# Comma-separated list of allowed origins (your web app Railway URL)
ALLOWED_ORIGINS="http://localhost:3000,https://your-web-app.up.railway.app"

# ─── Web App ────────────────────────────────────────────────────────────────
# Must be set at BUILD TIME (Next.js bakes it in)
NEXT_PUBLIC_API_URL="https://your-api.up.railway.app/api"
NEXT_PUBLIC_APP_NAME="DawoLink"

# ─── Optional: SMS / OTP (Waafi / Hormuud) ──────────────────────────────────
# WAAFI_API_KEY=""
# WAAFI_SENDER_ID=""

# ─── Railway deployment notes ───────────────────────────────────────────────
# 1. Create a Railway project at railway.app
# 2. Add PostgreSQL plugin  → DATABASE_URL is auto-set
# 3. Add Redis plugin       → REDIS_URL is auto-set
# 4. Service "api":
#    - Root dir: /  (builds from repo root using apps/api/Dockerfile)
#    - Set: JWT_SECRET, ALLOWED_ORIGINS
# 5. Service "web":
#    - Root dir: /  (builds from repo root using apps/web/Dockerfile)
#    - Set at build time: NEXT_PUBLIC_API_URL (your api Railway URL)
