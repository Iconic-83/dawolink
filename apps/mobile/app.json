{
  "expo": {
    "name": "DawoLink",
    "slug": "dawolink",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "dawolink",
    "userInterfaceStyle": "light",
    "splash": {
      "backgroundColor": "#180D62"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.dawolink.app",
      "infoPlist": {
        "NSFaceIDUsageDescription": "Use Face ID to sign in to DawoLink"
      }
    },
    "android": {
      "package": "com.dawolink.app",
      "adaptiveIcon": {
        "backgroundColor": "#180D62",
        "foregroundImage": "./assets/android-icon-foreground.png"
      }
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      "expo-local-authentication"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "apiUrl": "http://localhost:4001/api"
    }
  }
}
