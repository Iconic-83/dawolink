generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─────────────────────────────────────────────
// PLATFORM LAYER (DawoLink Super Admins)
// ─────────────────────────────────────────────

model PlatformAdmin {
  id           String    @id @default(cuid())
  email        String    @unique
  passwordHash String
  firstName    String
  lastName     String
  isActive     Boolean   @default(true)
  lastLoginAt  DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@map("platform_admins")
}

// ─────────────────────────────────────────────
// BILLING & SUBSCRIPTIONS
// ─────────────────────────────────────────────

model Subscription {
  id            String             @id @default(cuid())
  pharmacyId    String             @unique
  plan          Plan
  status        SubscriptionStatus @default(ACTIVE)
  billingCycle  BillingCycle       @default(MONTHLY)
  amount        Decimal            @db.Decimal(10, 2)
  currency      String             @default("USD")
  currentPeriodStart DateTime
  currentPeriodEnd   DateTime
  cancelledAt   DateTime?
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt

  pharmacy      Pharmacy           @relation(fields: [pharmacyId], references: [id], onDelete: Cascade)
  invoices      Invoice[]

  @@map("subscriptions")
}

model Invoice {
  id             String        @id @default(cuid())
  subscriptionId String
  pharmacyId     String
  invoiceNo      String        @unique
  amount         Decimal       @db.Decimal(10, 2)
  currency       String        @default("USD")
  status         InvoiceStatus @default(PENDING)
  dueDate        DateTime
  paidAt         DateTime?
  notes          String?
  createdAt      DateTime      @default(now())

  subscription   Subscription  @relation(fields: [subscriptionId], references: [id])

  @@map("invoices")
}

// ─────────────────────────────────────────────
// DYNAMIC RBAC
// ─────────────────────────────────────────────

model Permission {
  id          String   @id @default(cuid())
  key         String   @unique  // e.g. "create_sales", "edit_inventory"
  label       String            // Human-readable
  module      String            // "pos", "inventory", "analytics", etc.
  description String?
  createdAt   DateTime @default(now())

  rolePermissions RolePermission[]

  @@map("permissions")
}

model CustomRole {
  id          String   @id @default(cuid())
  pharmacyId  String
  name        String            // e.g. "Senior Pharmacist"
  description String?
  isSystem    Boolean  @default(false)  // true = default role seeded by platform
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  pharmacy    Pharmacy         @relation(fields: [pharmacyId], references: [id], onDelete: Cascade)
  permissions RolePermission[]
  users       User[]           @relation("UserCustomRole")

  @@unique([pharmacyId, name])
  @@map("custom_roles")
}

model RolePermission {
  roleId       String
  permissionId String

  role         CustomRole @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
  @@map("role_permissions")
}

// ─────────────────────────────────────────────
// GLOBAL MEDICINE DATABASE (Platform-level)
// ─────────────────────────────────────────────

model GlobalMedicine {
  id                   String   @id @default(cuid())
  name                 String
  genericName          String
  brandNames           String[]          // multiple brand names
  category             String
  form                 MedicineForm
  strength             String?
  unit                 String   @default("pcs")
  manufacturer         String?
  countryOfOrigin      String?
  requiresPrescription Boolean  @default(false)
  description          String?
  sideEffects          String?
  contraindications    String?
  storageConditions    String?
  atcCode              String?           // WHO ATC classification
  barcode              String?
  imageUrl             String?
  isApproved           Boolean  @default(true)
  isFlagged            Boolean  @default(false)  // suspicious/counterfeit
  flagReason           String?
  createdBy            String?           // platformAdmin id
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  @@index([genericName])
  @@index([category])
  @@map("global_medicines")
}

// ─────────────────────────────────────────────
// TENANCY & IDENTITY
// ─────────────────────────────────────────────

model Pharmacy {
  id          String   @id @default(cuid())
  name        String
  nameAr      String?
  slug        String   @unique
  email       String?
  phone       String
  address     String
  city        String
  country     String   @default("Somalia")
  licenseNo   String?
  logoUrl     String?
  isActive    Boolean  @default(true)
  plan        Plan     @default(STARTER)
  planExpiry  DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  branches       Branch[]
  users          User[]
  staffInvites   StaffInvite[]
  medicines      Medicine[]
  suppliers      Supplier[]
  auditLogs      AuditLog[]
  customRoles    CustomRole[]
  subscription   Subscription?
  medicineOrders MedicineOrder[]
  settings              PharmacySettings?
  inboxNotifications    InboxNotification[]
  reviews               PharmacyReview[]
  promotions            Promotion[]

  @@map("pharmacies")
}

model PharmacySettings {
  id                  String   @id @default(cuid())
  pharmacyId          String   @unique
  currency            String   @default("USD")
  timezone            String   @default("Africa/Mogadishu")
  taxEnabled          Boolean  @default(false)
  taxRate             Float    @default(0)
  taxLabel            String   @default("VAT")
  invoicePrefix       String   @default("INV")
  invoiceFooter       String   @default("")
  defaultReorderLevel Int      @default(10)
  expiryWarningDays   Int      @default(30)
  updatedAt           DateTime @updatedAt

  pharmacy Pharmacy @relation(fields: [pharmacyId], references: [id], onDelete: Cascade)

  @@map("pharmacy_settings")
}

model Branch {
  id          String   @id @default(cuid())
  pharmacyId  String
  name        String
  address     String
  phone       String?
  isMain      Boolean  @default(false)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  pharmacy    Pharmacy   @relation(fields: [pharmacyId], references: [id], onDelete: Cascade)
  users       User[]
  inventory   InventoryItem[]
  transactions Transaction[]
  transfers   StockTransfer[]  @relation("FromBranch")
  transfersIn StockTransfer[]  @relation("ToBranch")

  @@map("branches")
}

model User {
  id           String    @id @default(cuid())
  pharmacyId   String
  branchId     String?
  email        String    @unique
  phone        String?
  passwordHash String
  firstName    String
  lastName     String
  role           UserRole
  customRoleId   String?
  isActive       Boolean   @default(true)
  lastLoginAt    DateTime?
  twoFAEnabled   Boolean   @default(false)
  otpCode        String?
  otpExpiresAt   DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  pharmacy       Pharmacy    @relation(fields: [pharmacyId], references: [id], onDelete: Cascade)
  branch         Branch?     @relation(fields: [branchId], references: [id])
  customRole     CustomRole? @relation("UserCustomRole", fields: [customRoleId], references: [id])
  sessions       Session[]
  auditLogs      AuditLog[]
  transactions   Transaction[]
  sentInvites    StaffInvite[]  @relation("InvitedByUser")
  driverOrders   MedicineOrder[] @relation("DriverOrders")

  @@map("users")
}

model Session {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  device    String?
  ipAddress String?
  expiresAt DateTime
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

// ─────────────────────────────────────────────
// MEDICINE CATALOG
// ─────────────────────────────────────────────

model Medicine {
  id                 String             @id @default(cuid())
  pharmacyId         String
  name               String
  genericName        String?
  barcode            String?
  sku                String?
  category           String
  form               MedicineForm
  strength           String?
  unit               String             @default("pcs")
  requiresPrescription Boolean          @default(false)
  description        String?
  imageUrl           String?
  isActive           Boolean            @default(true)
  verificationStatus VerificationStatus @default(PENDING_VERIFICATION)
  verificationNotes  String?
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt
  deletedAt          DateTime?

  pharmacy        Pharmacy       @relation(fields: [pharmacyId], references: [id], onDelete: Cascade)
  inventory       InventoryItem[]
  transactionItems TransactionItem[]
  interactions    DrugInteraction[] @relation("MedicineA")
  interactsWith   DrugInteraction[] @relation("MedicineB")

  @@unique([pharmacyId, barcode])
  @@unique([pharmacyId, sku])
  @@map("medicines")
}

model InventoryItem {
  id             String    @id @default(cuid())
  branchId       String
  medicineId     String
  batchNo        String?
  supplierId     String?
  quantity       Int       @default(0)
  reorderLevel   Int       @default(10)
  costPrice      Decimal   @db.Decimal(10, 2)
  sellingPrice   Decimal   @db.Decimal(10, 2)
  expiryDate     DateTime?
  manufactureDate DateTime?
  location       String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  deletedAt      DateTime?

  branch         Branch    @relation(fields: [branchId], references: [id], onDelete: Cascade)
  medicine       Medicine  @relation(fields: [medicineId], references: [id])
  supplier       Supplier? @relation(fields: [supplierId], references: [id])

  @@map("inventory_items")
}

// ─────────────────────────────────────────────
// SUPPLIERS & PROCUREMENT
// ─────────────────────────────────────────────

model Supplier {
  id           String   @id @default(cuid())
  pharmacyId   String
  name         String
  contactName  String?
  email        String?
  phone        String
  address      String?
  city         String?
  rating       Float?
  isActive     Boolean  @default(true)
  notes        String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  pharmacy     Pharmacy        @relation(fields: [pharmacyId], references: [id], onDelete: Cascade)
  inventory    InventoryItem[]
  purchaseOrders PurchaseOrder[]
  users        SupplierUser[]

  @@map("suppliers")
}

model SupplierUser {
  id           String    @id @default(cuid())
  supplierId   String
  email        String    @unique
  passwordHash String
  firstName    String
  lastName     String
  phone        String?
  isActive     Boolean   @default(true)
  lastLoginAt  DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  supplier     Supplier  @relation(fields: [supplierId], references: [id], onDelete: Cascade)

  @@map("supplier_users")
}

model PurchaseOrder {
  id           String        @id @default(cuid())
  supplierId   String
  pharmacyId   String
  orderNo      String        @unique
  status       POStatus      @default(PENDING)
  totalAmount  Decimal       @db.Decimal(12, 2)
  notes                String?
  expectedDeliveryDate DateTime?
  orderedAt            DateTime      @default(now())
  receivedAt           DateTime?
  createdAt            DateTime      @default(now())
  updatedAt            DateTime      @updatedAt

  // Invoice & debt tracking
  supplierInvoiceNo    String?
  supplierNote         String?
  supplierConfirmedAt  DateTime?
  paymentStatus        PaymentStatus @default(UNPAID)
  amountPaid           Decimal       @default(0) @db.Decimal(12, 2)
  paidAt               DateTime?

  supplier     Supplier      @relation(fields: [supplierId], references: [id])
  items        POItem[]

  @@map("purchase_orders")
}

model POItem {
  id             String        @id @default(cuid())
  purchaseOrderId String
  medicineName   String
  quantity       Int
  unitCost       Decimal       @db.Decimal(10, 2)
  receivedQty    Int           @default(0)

  purchaseOrder  PurchaseOrder @relation(fields: [purchaseOrderId], references: [id], onDelete: Cascade)

  @@map("po_items")
}

// ─────────────────────────────────────────────
// MARKETPLACE USERS (B2C — public consumers)
// Completely separate from pharmacy staff (User)
// ─────────────────────────────────────────────

model AppUser {
  id           String    @id @default(cuid())
  name         String
  phone        String    @unique
  email        String?   @unique
  passwordHash String
  address      String?
  city         String?
  isActive     Boolean   @default(true)
  lastLoginAt  DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  orders            MedicineOrder[]
  pushSubscriptions AppPushSubscription[]
  reviews           PharmacyReview[]
  loyaltyAccount    LoyaltyAccount?

  @@map("app_users")
}

model AppPushSubscription {
  id        String   @id @default(cuid())
  appUserId String
  endpoint  String   @unique
  p256dh    String
  auth      String
  userAgent String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  appUser   AppUser  @relation(fields: [appUserId], references: [id], onDelete: Cascade)

  @@map("app_push_subscriptions")
}

model MedicineOrder {
  id              String              @id @default(cuid())
  orderNo         String              @unique
  appUserId       String
  pharmacyId      String
  branchId        String?
  status          MedicineOrderStatus @default(PENDING)
  paymentMethod   String?
  paymentStatus   String              @default("PENDING")
  deliveryType    DeliveryType        @default(DELIVERY)
  deliveryAddress String?
  deliveryCity    String?
  subtotal        Decimal             @db.Decimal(10, 2)
  deliveryFee     Decimal             @default(0) @db.Decimal(10, 2)
  total           Decimal             @db.Decimal(10, 2)
  prescriptionUrl          String?
  prescriptionStatus       PrescriptionStatus @default(NONE)
  prescriptionRejectReason String?
  notes                    String?
  driverId        String?
  confirmedAt     DateTime?
  pickedUpAt      DateTime?
  deliveredAt     DateTime?
  cancelledAt     DateTime?
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt

  appUser         AppUser             @relation(fields: [appUserId], references: [id])
  pharmacy        Pharmacy            @relation(fields: [pharmacyId], references: [id])
  driver          User?               @relation("DriverOrders", fields: [driverId], references: [id])
  items           MedicineOrderItem[]

  @@index([driverId])
  @@map("medicine_orders")
}

model MedicineOrderItem {
  id           String        @id @default(cuid())
  orderId      String
  medicineName String
  quantity     Int
  unitPrice    Decimal       @db.Decimal(10, 2)
  total        Decimal       @db.Decimal(10, 2)
  notes        String?

  order        MedicineOrder @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@map("medicine_order_items")
}

// ─────────────────────────────────────────────
// TRANSACTIONS / POS
// ─────────────────────────────────────────────

model Customer {
  id           String   @id @default(cuid())
  pharmacyId   String
  name         String
  phone        String?
  email        String?
  address      String?
  dateOfBirth  DateTime?
  allergies    String[]
  notes        String?
  balance      Decimal  @default(0) @db.Decimal(10, 2)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  transactions Transaction[]

  @@map("customers")
}

model Transaction {
  id              String          @id @default(cuid())
  branchId        String
  userId          String
  customerId      String?
  receiptNo       String          @unique
  type            TransactionType @default(SALE)
  paymentMethod   PaymentMethod   @default(CASH)
  subtotal        Decimal         @db.Decimal(12, 2)
  discount        Decimal         @default(0) @db.Decimal(10, 2)
  tax             Decimal         @default(0) @db.Decimal(10, 2)
  total           Decimal         @db.Decimal(12, 2)
  amountPaid      Decimal         @db.Decimal(12, 2)
  change          Decimal         @default(0) @db.Decimal(10, 2)
  status          TransactionStatus @default(COMPLETED)
  notes           String?
  offlineId       String?         @unique
  createdAt       DateTime        @default(now())

  branch          Branch          @relation(fields: [branchId], references: [id])
  user            User            @relation(fields: [userId], references: [id])
  customer        Customer?       @relation(fields: [customerId], references: [id])
  items           TransactionItem[]

  @@map("transactions")
}

model TransactionItem {
  id            String      @id @default(cuid())
  transactionId String
  medicineId    String
  quantity      Int
  unitPrice     Decimal     @db.Decimal(10, 2)
  discount      Decimal     @default(0) @db.Decimal(10, 2)
  total         Decimal     @db.Decimal(10, 2)
  batchNo       String?

  transaction   Transaction @relation(fields: [transactionId], references: [id], onDelete: Cascade)
  medicine      Medicine    @relation(fields: [medicineId], references: [id])

  @@map("transaction_items")
}

// ─────────────────────────────────────────────
// STOCK TRANSFERS
// ─────────────────────────────────────────────

model StockTransfer {
  id            String         @id @default(cuid())
  fromBranchId  String
  toBranchId    String
  transferNo    String         @unique
  status        TransferStatus @default(PENDING)
  notes         String?
  requestedAt   DateTime       @default(now())
  completedAt   DateTime?

  fromBranch    Branch         @relation("FromBranch", fields: [fromBranchId], references: [id])
  toBranch      Branch         @relation("ToBranch", fields: [toBranchId], references: [id])
  items         TransferItem[]

  @@map("stock_transfers")
}

model TransferItem {
  id             String        @id @default(cuid())
  transferId     String
  medicineName   String
  quantity       Int
  batchNo        String?

  transfer       StockTransfer @relation(fields: [transferId], references: [id], onDelete: Cascade)

  @@map("transfer_items")
}

// ─────────────────────────────────────────────
// RATINGS & REVIEWS
// ─────────────────────────────────────────────

model PharmacyReview {
  id         String   @id @default(cuid())
  appUserId  String
  pharmacyId String
  orderId    String   @unique
  rating     Int
  comment    String?
  createdAt  DateTime @default(now())

  appUser    AppUser  @relation(fields: [appUserId], references: [id])
  pharmacy   Pharmacy @relation(fields: [pharmacyId], references: [id], onDelete: Cascade)

  @@index([pharmacyId])
  @@map("pharmacy_reviews")
}

// ─────────────────────────────────────────────
// LOYALTY
// ─────────────────────────────────────────────

model LoyaltyAccount {
  id            String             @id @default(cuid())
  appUserId     String             @unique
  points        Int                @default(0)
  lifetimeEarned Int               @default(0)
  updatedAt     DateTime           @updatedAt

  appUser       AppUser            @relation(fields: [appUserId], references: [id], onDelete: Cascade)
  transactions  LoyaltyTransaction[]

  @@map("loyalty_accounts")
}

model LoyaltyTransaction {
  id        String   @id @default(cuid())
  accountId String
  type      LoyaltyTxType
  points    Int
  orderId   String?
  note      String?
  createdAt DateTime @default(now())

  account   LoyaltyAccount @relation(fields: [accountId], references: [id], onDelete: Cascade)

  @@map("loyalty_transactions")
}

enum LoyaltyTxType {
  EARNED
  REDEEMED
  ADJUSTED
}

// ─────────────────────────────────────────────
// PROMOTIONS
// ─────────────────────────────────────────────

model Promotion {
  id          String        @id @default(cuid())
  pharmacyId  String
  code        String
  description String?
  type        PromoType
  value       Decimal       @db.Decimal(10, 2)
  minOrder    Decimal       @default(0) @db.Decimal(10, 2)
  usageLimit  Int?
  usedCount   Int           @default(0)
  isActive    Boolean       @default(true)
  expiresAt   DateTime?
  createdAt   DateTime      @default(now())

  pharmacy    Pharmacy      @relation(fields: [pharmacyId], references: [id], onDelete: Cascade)

  @@unique([pharmacyId, code])
  @@map("promotions")
}

enum PromoType {
  PERCENTAGE
  FIXED_AMOUNT
}

// ─────────────────────────────────────────────
// CHAT
// ─────────────────────────────────────────────

model ChatRoom {
  id        String        @id @default(cuid())
  orderId   String        @unique
  createdAt DateTime      @default(now())

  messages  ChatMessage[]

  @@map("chat_rooms")
}

model ChatMessage {
  id         String      @id @default(cuid())
  roomId     String
  senderId   String
  senderType SenderType
  content    String?
  imageUrl   String?
  readAt     DateTime?
  createdAt  DateTime    @default(now())

  room       ChatRoom    @relation(fields: [roomId], references: [id], onDelete: Cascade)

  @@index([roomId, createdAt])
  @@map("chat_messages")
}

enum SenderType {
  CUSTOMER
  PHARMACY
}

// ─────────────────────────────────────────────
// INBOX NOTIFICATIONS
// ─────────────────────────────────────────────

model InboxNotification {
  id         String    @id @default(cuid())
  pharmacyId String
  type       NotifType
  title      String
  body       String
  link       String?
  isRead     Boolean   @default(false)
  createdAt  DateTime  @default(now())

  pharmacy   Pharmacy  @relation(fields: [pharmacyId], references: [id], onDelete: Cascade)

  @@index([pharmacyId, isRead])
  @@index([pharmacyId, createdAt(sort: Desc)])
  @@map("inbox_notifications")
}

enum NotifType {
  EXPIRY_ALERT
  LOW_STOCK
  SUBSCRIPTION_EXPIRING
  SUBSCRIPTION_EXPIRED
  STOCK_TRANSFER
  STAFF_INVITE
  SYSTEM
}

// ─────────────────────────────────────────────
// AUDIT & SECURITY
// ─────────────────────────────────────────────

model AuditLog {
  id         String   @id @default(cuid())
  pharmacyId String
  userId     String?
  action     String
  entity     String
  entityId   String?
  oldValue   Json?
  newValue   Json?
  ipAddress  String?
  userAgent  String?
  createdAt  DateTime @default(now())

  pharmacy   Pharmacy @relation(fields: [pharmacyId], references: [id], onDelete: Cascade)
  user       User?    @relation(fields: [userId], references: [id])

  @@map("audit_logs")
}

// ─────────────────────────────────────────────
// DRUG SAFETY
// ─────────────────────────────────────────────

model DrugInteraction {
  id          String            @id @default(cuid())
  medicineAId String
  medicineBId String
  severity    InteractionLevel
  description String

  medicineA   Medicine          @relation("MedicineA", fields: [medicineAId], references: [id])
  medicineB   Medicine          @relation("MedicineB", fields: [medicineBId], references: [id])

  @@unique([medicineAId, medicineBId])
  @@map("drug_interactions")
}

// ─────────────────────────────────────────────
// ENUMS
// ─────────────────────────────────────────────

enum Plan {
  STARTER
  PROFESSIONAL
  ENTERPRISE
}

enum UserRole {
  PHARMACY_OWNER
  BRANCH_MANAGER
  PHARMACIST
  CASHIER
  INVENTORY_STAFF
  DELIVERY_DRIVER
  AUDITOR
}

enum MedicineForm {
  TABLET
  CAPSULE
  SYRUP
  INJECTION
  CREAM
  DROPS
  INHALER
  POWDER
  SUPPOSITORY
  PATCH
  OTHER
}

enum POStatus {
  PENDING
  CONFIRMED
  PARTIALLY_RECEIVED
  RECEIVED
  CANCELLED
}

enum PaymentStatus {
  UNPAID
  PARTIAL
  PAID
}

enum TransactionType {
  SALE
  RETURN
  EXCHANGE
}

enum PaymentMethod {
  CASH
  EVC_PLUS
  ZAAD
  SAHAL
  PREMIER_WALLET
  CREDIT
  MIXED
}

enum TransactionStatus {
  COMPLETED
  PENDING
  CANCELLED
  REFUNDED
}

enum TransferStatus {
  PENDING
  IN_TRANSIT
  COMPLETED
  CANCELLED
}

enum InteractionLevel {
  MILD
  MODERATE
  SEVERE
  CONTRAINDICATED
}

enum SubscriptionStatus {
  ACTIVE
  PAST_DUE
  CANCELLED
  TRIALING
  SUSPENDED
}

enum BillingCycle {
  MONTHLY
  ANNUAL
}

enum InvoiceStatus {
  PENDING
  PAID
  OVERDUE
  CANCELLED
}

enum MedicineOrderStatus {
  PENDING
  CONFIRMED
  PREPARING
  READY_FOR_PICKUP
  OUT_FOR_DELIVERY
  DELIVERED
  CANCELLED
}

enum DeliveryType {
  DELIVERY
  PICKUP
}

enum VerificationStatus {
  PENDING_VERIFICATION
  VERIFIED
  REJECTED
}

model StaffInvite {
  id          String    @id @default(cuid())
  pharmacyId  String
  email       String
  role        UserRole
  branchId    String?
  token       String    @unique
  invitedById String
  acceptedAt  DateTime?
  expiresAt   DateTime
  createdAt   DateTime  @default(now())

  pharmacy    Pharmacy  @relation(fields: [pharmacyId], references: [id], onDelete: Cascade)
  invitedBy   User      @relation("InvitedByUser", fields: [invitedById], references: [id])

  @@index([token])
  @@map("staff_invites")
}

enum PrescriptionStatus {
  NONE
  PENDING_REVIEW
  VERIFIED
  REJECTED
}
